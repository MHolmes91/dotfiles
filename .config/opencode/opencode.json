{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "mcp": {
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@brave/brave-search-mcp-server",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  }
}
